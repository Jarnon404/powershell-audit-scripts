root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.ps1]
end_of_line = crlf

[*.psm1]
end_of_line = crlf

[*.psd1]
end_of_line = crlf

[*.md]
end_of_line = lf
trim_trailing_whitespace = false

[*.yml]
end_of_line = lf

[*.yaml]
end_of_line = lf

[*.json]
end_of_line = lf
